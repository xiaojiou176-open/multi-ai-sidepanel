{
  "compilerOptions": {
    "target": "ES2023",
    "lib": ["ES2023", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["node", "vitest/globals"],
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "rootDir": ".",
    "noEmit": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "checkJs": false,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "scripts/verify/**/*.ts",
    "src/utils/liveSiteDiagnostics.ts",
    "src/utils/modelConfig.ts",
    "src/utils/siteCapabilityMatrix.ts",
    "src/utils/types.ts"
  ],
  "exclude": ["**/*.test.ts", "**/*.test.tsx", "tests/**"]
}
