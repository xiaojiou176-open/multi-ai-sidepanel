# Optional selector override source.
# Leave empty to use the built-in selector map only.
VITE_SELECTOR_CONFIG_URL=

# Login-state-sensitive live/browser flows use the repo-owned persistent Chrome root.
# Default:
# PROMPT_SWITCHBOARD_BROWSER_USER_DATA_DIR=~/.cache/multi-ai-sidepanel/browser/chrome-user-data
# PROMPT_SWITCHBOARD_BROWSER_PROFILE_NAME=multi-ai-sidepanel
PROMPT_SWITCHBOARD_BROWSER_USER_DATA_DIR=
PROMPT_SWITCHBOARD_BROWSER_PROFILE_NAME=

# Optional explicit Chrome profile directory override.
# When set, this takes precedence over PROMPT_SWITCHBOARD_BROWSER_PROFILE_NAME.
PROMPT_SWITCHBOARD_BROWSER_PROFILE_DIRECTORY=

# Optional explicit Google Chrome executable override.
PROMPT_SWITCHBOARD_BROWSER_EXECUTABLE_PATH=

# Optional browser-window identity hints for the repo-owned live lane.
# These control the generated local identity tab opened by test:live:open-browser.
PROMPT_SWITCHBOARD_BROWSER_IDENTITY_LABEL=
PROMPT_SWITCHBOARD_BROWSER_IDENTITY_ACCENT=

# One-time bootstrap source.
# Default source root:
# PROMPT_SWITCHBOARD_BROWSER_SOURCE_USER_DATA_DIR=~/Library/Application Support/Google/Chrome
# Default source profile name:
# PROMPT_SWITCHBOARD_BROWSER_SOURCE_PROFILE_NAME=multi-ai-sidepanel
PROMPT_SWITCHBOARD_BROWSER_SOURCE_USER_DATA_DIR=
PROMPT_SWITCHBOARD_BROWSER_SOURCE_PROFILE_NAME=
PROMPT_SWITCHBOARD_BROWSER_SOURCE_PROFILE_DIRECTORY=

# Repo-owned external cache governance.
# Default root: ~/.cache/multi-ai-sidepanel
# Default cap: 2147483648 bytes (2 GB)
# Default ttl: 72 hours
# Note: ~/.cache/multi-ai-sidepanel/browser/chrome-user-data is persistent browser
# state and is excluded from ttl/cap pruning.
PROMPT_SWITCHBOARD_EXTERNAL_CACHE_ROOT=
PROMPT_SWITCHBOARD_EXTERNAL_CACHE_MAX_BYTES=
PROMPT_SWITCHBOARD_EXTERNAL_CACHE_TTL_HOURS=

# Optional live-lane overrides.
PROMPT_SWITCHBOARD_LIVE_CDP_URL=
PROMPT_SWITCHBOARD_LIVE_CDP_PORT=
PROMPT_SWITCHBOARD_LIVE_BROWSER_CHANNEL=
PROMPT_SWITCHBOARD_LIVE_ATTACH_MODE=
