{
  "name": "multi-ai-sidepanel",
  "private": true,
  "version": "0.2.2",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:mcp": "tsc -p tsconfig.mcp.json",
    "mcp:server": "tsx mcp/server.ts",
    "mcp:doctor": "tsx mcp/doctor.ts",
    "mcp:operator": "tsx mcp/operator.ts",
    "test:mcp:unit": "vitest run mcp/bridgeServer.test.ts mcp/operatorShared.test.ts mcp/server.test.ts mcp/doctor.test.ts mcp/operator.test.ts --maxWorkers=1",
    "test:mcp:smoke": "tsx mcp/smoke.ts",
    "test:integration-kits": "node scripts/quality/check-integration-kits.mjs",
    "preview": "vite preview",
    "release:bundle": "npm run build && node scripts/release/build-extension-bundle.mjs",
    "release:host-kits": "node scripts/release/build-host-kit-bundles.mjs",
    "release:sbom": "node scripts/release/generate-release-sbom.mjs",
    "marketing:assets": "node scripts/marketing/capture-marketing-assets.mjs",
    "secrets:setup": "node scripts/quality/setup-git-secrets.mjs",
    "scan:secrets:staged": "node scripts/quality/run-gitleaks.mjs staged && node scripts/quality/run-git-secrets-scan.mjs staged",
    "secrets:scan": "node scripts/quality/run-gitleaks.mjs current && node scripts/quality/run-git-secrets-scan.mjs current",
    "secrets:scan:history": "node scripts/quality/run-gitleaks.mjs history && node scripts/quality/run-git-secrets-scan.mjs history",
    "verify:sensitive-surface": "node scripts/quality/verify-sensitive-surface.mjs",
    "verify:host-frontdoor": "node scripts/quality/verify-host-frontdoor.mjs",
    "verify:host-security": "node scripts/quality/verify-host-security.mjs",
    "verify:host-sensitive-surface": "node scripts/quality/verify-host-sensitive-surface.mjs",
    "verify:host-safety": "node scripts/quality/verify-host-safety.mjs",
    "verify:host-actions-policy": "node scripts/quality/verify-host-actions-policy.mjs",
    "verify:host-release-proof": "node scripts/quality/verify-host-release-proof.mjs",
    "verify:host:doctor": "node scripts/quality/verify-host-doctor.mjs",
    "verify:host:pack": "npm run verify:host-actions-policy && npm run verify:host-security && npm run verify:host-frontdoor && npm run verify:host-sensitive-surface",
    "verify:store-readiness": "node scripts/quality/verify-store-readiness.mjs",
    "verify:release-baseline": "node scripts/verify/run-release-baseline.mjs",
    "verify:release-closure": "npm run verify:host:pack && npm run verify:host-release-proof",
    "precommit:run": "pre-commit run --all-files --hook-stage manual --show-diff-on-failure",
    "test:security": "npm run verify:host-safety && npm run verify:sensitive-surface && npm run precommit:run && npm run secrets:scan:history",
    "test:guard": "node scripts/quality/anti-placebo-scan.mjs",
    "test:brand": "node scripts/quality/check-branding.mjs",
    "test:frontdoor:assets": "node scripts/quality/check-frontdoor-assets.mjs",
    "test:frontdoor:links": "node scripts/quality/check-frontdoor-links.mjs",
    "test:frontdoor": "npm run test:frontdoor:assets && npm run test:frontdoor:links && vitest run tests/frontdoor/frontdoor.contract.test.ts",
    "test": "npm run test:guard && npm run test:brand && vitest run --maxWorkers=75%",
    "test:watch": "npm run test:guard && vitest --maxWorkers=75%",
    "test:coverage": "npm run test:guard && node scripts/quality/run-vitest-coverage.mjs",
    "check:verify-scripts": "tsc -p tsconfig.verify.json",
    "test:e2e": "node scripts/verify/run-playwright-suite.mjs --workers=50%",
    "test:e2e:shell": "node scripts/verify/run-playwright-suite.mjs tests/e2e/extension.spec.ts --workers=50%",
    "test:drift": "vitest run tests/drift/selector-config.contract.test.ts tests/drift/verification-contract.test.ts",
    "test:live:doctor": "node scripts/verify/live-smoke-doctor.mjs",
    "test:live:bootstrap-profile": "node scripts/verify/bootstrap-live-browser-profile.mjs",
    "test:live:probe": "tsx scripts/verify/live-site-probe.ts",
    "test:live:diagnose": "tsx scripts/verify/live-diagnose.ts",
    "test:live:support-bundle": "tsx scripts/verify/live-support-bundle.ts",
    "test:switchyard-runtime:probe": "tsx scripts/verify/switchyard-runtime-analyst-probe.ts",
    "test:live:open-browser": "node scripts/verify/open-live-browser.mjs",
    "test:live": "node scripts/verify/run-live-smoke.mjs",
    "test:push-gate": "npm run clean:runtime && npm run test:security && npm run lint && npm run check:verify-scripts && npm run build:mcp && npm run check:root && npm run test:guard && npm run test:brand && npm run test:frontdoor && npm run test:drift && npm run test:mcp:unit",
    "test:ci": "npm run clean:runtime && npm run test:security && npm run lint && npm run check:verify-scripts && npm run build && npm run build:mcp && npm run check:root && npm run test:brand && npm run test:frontdoor && npm run test:coverage && npm run test:drift && npm run test:mcp:unit && npm run test:mcp:smoke && npm run test:integration-kits",
    "test:ci:full": "npm run test:ci && npm run test:e2e",
    "audit:disk:repo": "node scripts/quality/report-repo-disk-usage.mjs",
    "clean:runtime:dry-run": "node scripts/quality/clean-runtime-artifacts.mjs --dry-run",
    "clean:runtime": "node scripts/quality/clean-runtime-artifacts.mjs",
    "clean:repo:light": "node scripts/quality/clean-repo-footprint.mjs --profile=light",
    "clean:repo:heavy": "node scripts/quality/clean-repo-footprint.mjs --profile=heavy",
    "check:root": "node scripts/quality/check-root-allowlist.mjs",
    "lint": "eslint . --ext .ts,.tsx",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css,md}\"",
    "prepare": "husky && node scripts/quality/setup-git-secrets.mjs --optional"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@types/react-window": "^2.0.0",
    "clsx": "^2.1.1",
    "i18next": "^26.0.2",
    "lucide-react": "^1.7.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.6.6",
    "react-window": "^2.2.7",
    "tailwind-merge": "^3.5.0",
    "ws": "^8.20.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.4.0",
    "@cyclonedx/cyclonedx-npm": "^4.2.1",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/postcss": "^4.1.17",
    "@testing-library/jest-dom": "^6.6.4",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/chrome": "^0.1.38",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@types/react-i18next": "^7.8.3",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.58.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "autoprefixer": "^10.4.27",
    "baseline-browser-mapping": "^2.10.12",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.9",
    "husky": "^9.1.7",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.20.6",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.3",
    "vitest": "^4.0.13"
  },
  "overrides": {
    "picomatch@^2.2.2": "2.3.2",
    "picomatch@^2.3.1": "2.3.2",
    "picomatch@^4.0.3": "4.0.4",
    "@crxjs/vite-plugin": {
      "cheerio": "1.2.0",
      "rollup": "2.80.0"
    },
    "@eslint/config-array": {
      "minimatch": "3.1.4"
    },
    "@eslint/eslintrc": {
      "minimatch": "3.1.4"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": "10.2.4"
    },
    "cheerio": {
      "undici": "7.24.5"
    },
    "eslint": {
      "minimatch": "3.1.4"
    },
    "eslint-plugin-react": {
      "minimatch": "3.1.4"
    },
    "flatted": "3.4.2",
    "flat-cache": {
      "flatted": "3.4.2"
    },
    "vite": {
      "rollup": "4.59.1"
    }
  }
}
